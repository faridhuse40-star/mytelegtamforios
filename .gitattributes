# Default behaviour: autodetect text and normalize to LF in repo.
* text=auto eol=lf

# Files that MUST stay LF (executed in Linux/macOS runners or as shell scripts).
*.sh        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
gradlew     text eol=lf
*.gradle    text eol=lf
Dockerfile  text eol=lf
*.dockerfile text eol=lf

# Windows-only files keep CRLF.
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Binaries — never alter.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       text
*.apk       binary
*.ipa       binary
*.keystore  binary
*.jks       binary
