{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://messenger-api-far.fly.dev",
        "EXPO_PUBLIC_SOCKET_URL": "https://messenger-api-far.fly.dev"
      }
    },
    "production": {
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://messenger-api-far.fly.dev",
        "EXPO_PUBLIC_SOCKET_URL": "https://messenger-api-far.fly.dev"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
